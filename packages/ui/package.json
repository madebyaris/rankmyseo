{
  "name": "@rankmyseo/ui",
  "version": "1.0.2",
  "type": "module",
  "description": "RankMySEO prebuilt dashboard widgets and renderer",
  "license": "Apache-2.0",
  "homepage": "https://github.com/madebyaris/rankmyseo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebyaris/rankmyseo.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/madebyaris/rankmyseo/issues"
  },
  "keywords": [
    "seo",
    "react",
    "dashboard",
    "widgets",
    "rankmyseo"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "publint": "publint"
  },
  "dependencies": {
    "@rankmyseo/core": "workspace:*",
    "@rankmyseo/react": "workspace:*",
    "recharts": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.0.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "publint": "^0.3.15"
  },
  "publishConfig": {
    "access": "public"
  }
}
