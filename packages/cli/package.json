{
  "name": "@rankmyseo/cli",
  "version": "0.0.0",
  "type": "module",
  "description": "RankMySEO CLI — scaffold config, migrate, schedule",
  "license": "Apache-2.0",
  "bin": {
    "rankmyseo": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "publint": "publint"
  },
  "dependencies": {
    "@rankmyseo/core": "workspace:*",
    "@rankmyseo/datasource": "workspace:*",
    "@rankmyseo/scheduler": "workspace:*",
    "@rankmyseo/storage": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "publint": "^0.3.15"
  },
  "publishConfig": {
    "access": "public"
  }
}
