{
  "name": "@rankmyseo/storage-prisma",
  "version": "1.0.0",
  "type": "module",
  "description": "RankMySEO RankStore adapter backed by Prisma (Postgres)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/madebyaris/rankmyseo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebyaris/rankmyseo.git",
    "directory": "packages/storage-prisma"
  },
  "bugs": {
    "url": "https://github.com/madebyaris/rankmyseo/issues"
  },
  "keywords": [
    "seo",
    "prisma",
    "postgres",
    "storage",
    "rankmyseo"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "generate": "DATABASE_URL=${DATABASE_URL:-postgresql://localhost:5432/rankmyseo} prisma generate",
    "build": "pnpm run generate && tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "publint": "publint"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@rankmyseo/core": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "prisma": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prisma": "^6.16.2",
    "publint": "^0.3.15",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
