{
  "name": "@rankmyseo/scheduler",
  "version": "0.1.0",
  "type": "module",
  "description": "RankMySEO scheduler adapters (node-cron, manual)",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "publint": "publint"
  },
  "dependencies": {
    "@rankmyseo/core": "workspace:*",
    "node-cron": "^4.2.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "publint": "^0.3.15"
  },
  "publishConfig": {
    "access": "public"
  }
}
