{
  "name": "@rankmyseo/core",
  "version": "0.2.0",
  "type": "module",
  "description": "RankMySEO core domain models, ports, and conformance tests",
  "license": "Apache-2.0",
  "homepage": "https://github.com/madebyaris/rankmyseo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebyaris/rankmyseo.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/madebyaris/rankmyseo/issues"
  },
  "keywords": [
    "seo",
    "seo-audit",
    "rank-tracking",
    "core-web-vitals",
    "headless",
    "zod",
    "rankmyseo"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schemas": {
      "import": {
        "types": "./dist/schemas/index.d.ts",
        "default": "./dist/schemas/index.js"
      },
      "require": {
        "types": "./dist/schemas/index.d.cts",
        "default": "./dist/schemas/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      },
      "require": {
        "types": "./dist/testing/index.d.cts",
        "default": "./dist/testing/index.cjs"
      }
    },
    "./json-schema": {
      "import": {
        "types": "./dist/json-schema.d.ts",
        "default": "./dist/json-schema.js"
      },
      "require": {
        "types": "./dist/json-schema.d.cts",
        "default": "./dist/json-schema.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "publint": "publint"
  },
  "dependencies": {
    "jiti": "^2.6.1",
    "zod": "^4.1.12",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "publint": "^0.3.15"
  },
  "publishConfig": {
    "access": "public"
  }
}
