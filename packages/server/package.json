{
  "name": "@rankmyseo/server",
  "version": "1.0.0",
  "type": "module",
  "description": "Framework-agnostic RankMySEO HTTP handler",
  "license": "Apache-2.0",
  "homepage": "https://github.com/madebyaris/rankmyseo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebyaris/rankmyseo.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/madebyaris/rankmyseo/issues"
  },
  "keywords": [
    "seo",
    "http",
    "api",
    "web-standard",
    "rankmyseo"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "publint": "publint"
  },
  "dependencies": {
    "@rankmyseo/agent": "workspace:*",
    "@rankmyseo/core": "workspace:*",
    "@rankmyseo/datasource": "workspace:*",
    "@rankmyseo/scanner": "workspace:*",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@rankmyseo/storage": "workspace:*",
    "@types/node": "^24.10.1",
    "ai": "^6.0.116",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "publint": "^0.3.15"
  },
  "publishConfig": {
    "access": "public"
  }
}
