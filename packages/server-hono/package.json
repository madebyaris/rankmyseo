{
  "name": "@rankmyseo/server-hono",
  "version": "1.0.0",
  "type": "module",
  "description": "Hono adapter for RankMySEO server handler",
  "license": "Apache-2.0",
  "homepage": "https://github.com/madebyaris/rankmyseo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebyaris/rankmyseo.git",
    "directory": "packages/server-hono"
  },
  "bugs": {
    "url": "https://github.com/madebyaris/rankmyseo/issues"
  },
  "keywords": [
    "seo",
    "hono",
    "adapter",
    "rankmyseo"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "publint": "publint"
  },
  "dependencies": {
    "@rankmyseo/core": "workspace:*",
    "@rankmyseo/server": "workspace:*"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@rankmyseo/storage": "workspace:*",
    "hono": "^4.10.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "publint": "^0.3.15"
  },
  "publishConfig": {
    "access": "public"
  }
}
