{
  "name": "rankmyseo",
  "version": "0.3.0",
  "type": "module",
  "description": "Install RankMySEO — interactive package picker (recommended, full, or custom)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/madebyaris/rankmyseo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madebyaris/rankmyseo.git",
    "directory": "packages/rankmyseo"
  },
  "bugs": {
    "url": "https://github.com/madebyaris/rankmyseo/issues"
  },
  "keywords": [
    "seo",
    "rankmyseo",
    "installer",
    "schema",
    "audit"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "rankmyseo": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "publint": "publint"
  },
  "dependencies": {
    "@rankmyseo/installer": "workspace:*"
  },
  "peerDependencies": {
    "@rankmyseo/cli": "*"
  },
  "peerDependenciesMeta": {
    "@rankmyseo/cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rankmyseo/cli": "workspace:*",
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "publint": "^0.3.15"
  },
  "publishConfig": {
    "access": "public"
  }
}
